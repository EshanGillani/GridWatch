<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ── Swipe cards ──
  const cards = [
    { name: 'Cooper', emoji: '🐶', note: 'Woof! Cooper liked you back! 🦴' },
    { name: 'Luna',   emoji: '🐱', note: 'Luna is interested! Purr... 🎀' },
    { name: 'Biscuit',emoji: '🐰', note: 'Biscuit hopped your way! 🥕' },
  ];
  let cardIdx = 0;

  function swipeCard(dir) {
    const stack = document.getElementById('cardStack');
    const topCard = stack.querySelector('.pet-card:last-child');
    if (!topCard) return;

    if (dir === 'right') {
      topCard.classList.add('swiped-right');
      const c = cards[cardIdx % cards.length];
      setTimeout(() => openModal(c.name, c.emoji, 'your pet'), 300);
    } else if (dir === 'left') {
      topCard.classList.add('swiped-left');
      showToast('👋 Passed');
    } else {
      topCard.classList.add('swiped-right');
      showToast('⭐ Super liked!');
      const c = cards[cardIdx % cards.length];
      setTimeout(() => openModal(c.name, c.emoji, 'your pet'), 300);
    }
    cardIdx++;
    setTimeout(() => topCard.remove(), 500);
  }

  // ── Modal ──
  function openModal(name, emoji, myPet) {
    document.getElementById('modalPets').textContent = `🐾 ${emoji} ❤️ 🐾`;
    document.getElementById('modalText').textContent = `${myPet.charAt(0).toUpperCase()+myPet.slice(1)} and ${name} both liked each other! Time to set up a playdate!`;
    document.getElementById('matchModal').classList.add('show');
  }

  function closeModal(e) {
    if (!e || e.target === document.getElementById('matchModal')) {
      document.getElementById('matchModal').classList.remove('show');
    }
  }

  // ── Toast ──
  let toastTimer;
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
  }

  // ── Heart toggle ──
  function toggleLike(btn) {
    btn.classList.toggle('liked');
    if (btn.classList.contains('liked')) {
      btn.textContent = '🧡';
      showToast('💕 Added to likes!');
    } else {
      btn.textContent = '❤️';
    }
  }

  // ── Filter chips ──
  function setFilter(el, val) {
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    showToast(`Showing ${val} 🔍`);
  }

  // ── Keyboard swipe ──
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') swipeCard('right');
    if (e.key === 'ArrowLeft')  swipeCard('left');
    if (e.key === 'ArrowUp')    swipeCard('super');
  });
</script>
