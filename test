<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PawMatch — Find Your Pet's Soulmate</title>
<link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #FFF8F0;
    --orange: #FF6B35;
    --pink: #FF4F8B;
    --yellow: #FFD166;
    --teal: #06D6A0;
    --purple: #845EC2;
    --dark: #2D2D2D;
    --card-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    min-height: 100vh;
    overflow-x: hidden;
    cursor: default;
  }

  /* Animated background dots */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, #FFD16633 1.5px, transparent 1.5px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: white;
    border-bottom: 3px solid var(--dark);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
    box-shadow: 0 4px 0 var(--yellow);
  }

  .logo {
    font-family: 'Boogaloo', cursive;
    font-size: 2rem;
    color: var(--orange);
    letter-spacing: 1px;
    text-decoration: none;
  }
  .logo span { color: var(--pink); }

  .nav-links {
    display: flex; gap: 0.5rem; align-items: center;
  }

  .nav-btn {
    padding: 0.4rem 1.1rem;
    border-radius: 999px;
    border: 2.5px solid var(--dark);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.9rem;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
    box-shadow: 3px 3px 0 var(--dark);
  }
  .nav-btn:hover { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 var(--dark); }
  .nav-btn:active { transform: translate(1px,1px); box-shadow: 1px 1px 0 var(--dark); }
  .nav-btn.primary { background: var(--orange); color: white; }
  .nav-btn.ghost { background: white; color: var(--dark); }

  /* ── HERO ── */
  .hero {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 2rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
  }

  .hero-text h1 {
    font-family: 'Boogaloo', cursive;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 1.05;
    color: var(--dark);
  }
  .hero-text h1 em { color: var(--pink); font-style: normal; }
  .hero-text h1 strong { color: var(--orange); }

  .hero-text p {
    margin-top: 1.2rem;
    font-size: 1.15rem;
    color: #555;
    max-width: 440px;
    line-height: 1.6;
  }

  .hero-cta {
    margin-top: 2rem;
    display: flex; gap: 1rem; flex-wrap: wrap;
  }

  .btn-big {
    padding: 0.9rem 2.2rem;
    border-radius: 999px;
    border: 3px solid var(--dark);
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.12s, box-shadow 0.12s;
    box-shadow: 5px 5px 0 var(--dark);
    text-decoration: none;
    display: inline-block;
  }
  .btn-big:hover { transform: translate(-3px,-3px); box-shadow: 8px 8px 0 var(--dark); }
  .btn-big:active { transform: translate(2px,2px); box-shadow: 2px 2px 0 var(--dark); }
  .btn-big.orange { background: var(--orange); color: white; }
  .btn-big.pink { background: var(--pink); color: white; }

  .stats {
    margin-top: 3rem;
    display: flex; gap: 2.5rem;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: 'Boogaloo', cursive;
    font-size: 2.2rem;
    color: var(--orange);
    display: block;
  }
  .stat-label { font-size: 0.85rem; color: #888; font-weight: 700; }

  /* ── SWIPE CARD STACK ── */
  .card-stack {
    position: relative;
    width: 340px;
    height: 460px;
    margin: 0 auto;
  }

  .pet-card {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    border: 3px solid var(--dark);
    overflow: hidden;
    box-shadow: var(--card-shadow);
    cursor: grab;
    transition: transform 0.3s ease;
    user-select: none;
  }

  .pet-card:active { cursor: grabbing; }

  .pet-card:nth-child(3) { transform: rotate(-4deg) translate(-6px, 10px); z-index: 1; }
  .pet-card:nth-child(2) { transform: rotate(2deg) translate(4px, 5px); z-index: 2; }
  .pet-card:nth-child(1) { transform: rotate(0deg); z-index: 3; }

  .pet-card.swiped-right {
    transform: translateX(150%) rotate(20deg) !important;
    transition: transform 0.4s ease !important;
  }
  .pet-card.swiped-left {
    transform: translateX(-150%) rotate(-20deg) !important;
    transition: transform 0.4s ease !important;
  }

  .card-img {
    width: 100%; height: 280px;
    object-fit: cover;
    display: block;
    background: linear-gradient(135deg, #ffd166 0%, #ff6b35 100%);
    position: relative;
  }

  .card-emoji {
    font-size: 7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 280px;
    background: linear-gradient(135deg, var(--bg1, #ffd166), var(--bg2, #ff6b35));
  }

  .card-body {
    background: white;
    padding: 1.2rem 1.3rem 1rem;
  }

  .card-name-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .card-name {
    font-family: 'Boogaloo', cursive;
    font-size: 1.7rem;
    color: var(--dark);
  }
  .card-age {
    font-size: 1rem;
    color: #888;
    font-weight: 700;
  }

  .card-tags {
    display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.6rem;
  }
  .tag {
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    border: 2px solid var(--dark);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .card-bio {
    margin-top: 0.6rem;
    font-size: 0.88rem;
    color: #555;
    line-height: 1.5;
  }

  /* ── SWIPE BUTTONS ── */
  .swipe-btns {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    position: relative; z-index: 10;
  }

  .swipe-btn {
    width: 58px; height: 58px;
    border-radius: 50%;
    border: 3px solid var(--dark);
    font-size: 1.6rem;
    cursor: pointer;
    box-shadow: 4px 4px 0 var(--dark);
    transition: transform 0.12s, box-shadow 0.12s;
    display: flex; align-items: center; justify-content: center;
  }
  .swipe-btn:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--dark); }
  .swipe-btn:active { transform: translate(2px,2px); box-shadow: 1px 1px 0 var(--dark); }
  .swipe-btn.nope { background: #fff; }
  .swipe-btn.like { background: var(--pink); }
  .swipe-btn.super { background: var(--yellow); }

  /* ── SECTION DIVIDER ── */
  .section-divider {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    margin: 2rem 0 0;
  }

  /* ── HOW IT WORKS ── */
  .how-section {
    position: relative; z-index: 1;
    background: var(--dark);
    padding: 5rem 2rem;
    text-align: center;
  }

  .how-section h2 {
    font-family: 'Boogaloo', cursive;
    font-size: 3rem;
    color: var(--yellow);
    margin-bottom: 3rem;
  }

  .steps {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 900px;
    margin: 0 auto;
  }

  .step {
    background: white;
    border: 3px solid var(--yellow);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    width: 220px;
    box-shadow: 6px 6px 0 var(--yellow);
    position: relative;
    transition: transform 0.15s;
  }
  .step:hover { transform: translate(-3px,-3px); }

  .step-num {
    font-family: 'Boogaloo', cursive;
    font-size: 3.5rem;
    color: var(--orange);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .step-icon { font-size: 2.2rem; margin-bottom: 0.5rem; }
  .step h3 {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }
  .step p { font-size: 0.88rem; color: #555; line-height: 1.5; }

  /* ── MATCHES SECTION ── */
  .matches-section {
    position: relative; z-index: 1;
    padding: 5rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    display: flex; align-items: baseline; gap: 1rem; margin-bottom: 2.5rem;
  }
  .section-header h2 {
    font-family: 'Boogaloo', cursive;
    font-size: 2.8rem;
    color: var(--dark);
  }
  .section-header .badge {
    background: var(--pink);
    color: white;
    border: 2.5px solid var(--dark);
    border-radius: 999px;
    padding: 0.15rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 900;
    box-shadow: 3px 3px 0 var(--dark);
  }

  .matches-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .match-card {
    border: 3px solid var(--dark);
    border-radius: 20px;
    overflow: hidden;
    background: white;
    box-shadow: 5px 5px 0 var(--dark);
    transition: transform 0.15s, box-shadow 0.15s;
    cursor: pointer;
  }
  .match-card:hover { transform: translate(-3px,-3px); box-shadow: 8px 8px 0 var(--dark); }

  .match-emoji {
    height: 150px;
    display: flex; align-items: center; justify-content: center;
    font-size: 5rem;
  }
  .match-info { padding: 0.8rem 1rem 1rem; }
  .match-name {
    font-family: 'Boogaloo', cursive;
    font-size: 1.3rem;
    color: var(--dark);
  }
  .match-detail {
    font-size: 0.82rem;
    color: #888;
    font-weight: 700;
    margin-top: 0.1rem;
  }
  .match-compat {
    margin-top: 0.6rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .compat-bar {
    flex: 1;
    height: 8px;
    background: #eee;
    border-radius: 999px;
    border: 1.5px solid var(--dark);
    overflow: hidden;
  }
  .compat-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--orange), var(--pink));
    border-radius: 999px;
  }
  .compat-pct { font-size: 0.8rem; font-weight: 900; color: var(--orange); }

  /* ── PROFILES SECTION ── */
  .profiles-section {
    position: relative; z-index: 1;
    background: linear-gradient(135deg, #fff0f5, #fff8ee);
    padding: 5rem 2rem;
    border-top: 3px solid var(--dark);
    border-bottom: 3px solid var(--dark);
  }

  .profiles-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .profiles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .profile-card {
    border: 3px solid var(--dark);
    border-radius: 24px;
    background: white;
    box-shadow: 6px 6px 0 var(--dark);
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
    cursor: pointer;
  }
  .profile-card:hover { transform: translate(-3px,-3px); box-shadow: 10px 10px 0 var(--dark); }

  .profile-header {
    padding: 1.5rem 1.5rem 1rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .profile-avatar {
    width: 72px; height: 72px;
    border-radius: 50%;
    border: 3px solid var(--dark);
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem;
    flex-shrink: 0;
  }
  .profile-meta {}
  .profile-meta .name {
    font-family: 'Boogaloo', cursive;
    font-size: 1.4rem;
    color: var(--dark);
  }
  .profile-meta .species { font-size: 0.85rem; color: #888; font-weight: 700; }

  .profile-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    padding: 0 1rem 1rem;
  }
  .profile-photo {
    border-radius: 12px;
    border: 2px solid var(--dark);
    height: 90px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.8rem;
    overflow: hidden;
  }
  .profile-photo:first-child { grid-column: 1 / -1; height: 120px; font-size: 3.5rem; }

  .profile-footer {
    padding: 0.8rem 1.5rem 1.2rem;
    border-top: 2px solid #eee;
    display: flex; justify-content: space-between; align-items: center;
  }
  .looking-for { font-size: 0.82rem; color: #777; font-weight: 700; }
  .heart-btn {
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 2.5px solid var(--dark);
    background: var(--pink);
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--dark);
    transition: transform 0.12s;
    display: flex; align-items: center; justify-content: center;
  }
  .heart-btn:hover { transform: scale(1.15); }
  .heart-btn.liked { background: var(--orange); }

  /* ── MATCH MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.7);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
  }
  .modal-overlay.show { opacity: 1; pointer-events: all; }

  .modal {
    background: white;
    border: 4px solid var(--dark);
    border-radius: 28px;
    padding: 3rem 2.5rem;
    text-align: center;
    max-width: 380px;
    box-shadow: 10px 10px 0 var(--dark);
    transform: scale(0.85);
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  }
  .modal-overlay.show .modal { transform: scale(1); }

  .modal-hearts { font-size: 3.5rem; margin-bottom: 0.5rem; animation: heartbeat 0.6s infinite; }
  @keyframes heartbeat { 0%,100%{transform:scale(1)} 50%{transform:scale(1.2)} }

  .modal h2 {
    font-family: 'Boogaloo', cursive;
    font-size: 2.5rem;
    color: var(--pink);
    margin-bottom: 0.5rem;
  }
  .modal p { color: #555; line-height: 1.6; margin-bottom: 1.5rem; }

  .modal-pets { font-size: 4rem; margin: 1rem 0; }

  /* ── FOOTER ── */
  footer {
    position: relative; z-index: 1;
    background: var(--dark);
    color: white;
    text-align: center;
    padding: 3rem 2rem;
  }
  footer .footer-logo {
    font-family: 'Boogaloo', cursive;
    font-size: 2.5rem;
    color: var(--orange);
    margin-bottom: 0.5rem;
  }
  footer .footer-logo span { color: var(--pink); }
  footer p { color: #aaa; font-size: 0.9rem; }
  .footer-links { display: flex; justify-content: center; gap: 2rem; margin: 1rem 0; }
  .footer-links a { color: var(--yellow); font-weight: 700; font-size: 0.9rem; text-decoration: none; }
  .footer-links a:hover { text-decoration: underline; }

  /* ── TOAST ── */
  .toast {
    position: fixed;
    bottom: 2rem; left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--dark);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 1rem;
    z-index: 999;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    border: 3px solid var(--yellow);
    box-shadow: 5px 5px 0 var(--yellow);
    pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ── FILTER BAR ── */
  .filter-bar {
    display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.5rem;
  }
  .filter-chip {
    padding: 0.35rem 1rem;
    border: 2.5px solid var(--dark);
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.85rem;
    cursor: pointer;
    background: white;
    transition: all 0.12s;
    box-shadow: 3px 3px 0 var(--dark);
  }
  .filter-chip:hover, .filter-chip.active { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--dark); }
  .filter-chip.active { background: var(--orange); color: white; border-color: var(--orange); }

  /* responsive */
  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; text-align: center; }
    .hero-text p { margin: 1rem auto 0; }
    .hero-cta { justify-content: center; }
    .stats { justify-content: center; }
    .card-stack { margin: 2rem auto 0; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="logo" href="#">Paw<span>Match</span> 🐾</a>
  <div class="nav-links">
    <button class="nav-btn ghost" onclick="showToast('📧 Messages feature coming soon!')">Messages 💌</button>
    <button class="nav-btn primary" onclick="showToast('👤 Sign up to create your pet\'s profile!')">Create Profile</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text">
    <h1>Find your pet's<br><em>perfect</em><br><strong>match.</strong></h1>
    <p>Because even your furball deserves a soulmate. Swipe, sniff, and fall in love — the cutest dating app for pets on the planet. 🐶🐱🐰</p>
    <div class="hero-cta">
      <button class="btn-big orange" onclick="showToast('🐾 Creating your pet\'s profile...')">Start Matching</button>
      <button class="btn-big pink" onclick="document.getElementById('browse').scrollIntoView({behavior:'smooth'})">Browse Pets</button>
    </div>
    <div class="stats">
      <div class="stat-item">
        <span class="stat-num">148K+</span>
        <span class="stat-label">HAPPY PETS</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">32K</span>
        <span class="stat-label">MATCHES MADE</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">4.9 ⭐</span>
        <span class="stat-label">PET RATING</span>
      </div>
    </div>
  </div>

  <!-- SWIPE CARDS -->
  <div>
    <div class="card-stack" id="cardStack">
      <!-- Card 3 (back) -->
      <div class="pet-card">
        <div class="card-emoji" style="--bg1:#c3f0ca;--bg2:#06d6a0">🐰</div>
        <div class="card-body">
          <div class="card-name-row">
            <span class="card-name">Biscuit</span>
            <span class="card-age">2 yrs</span>
          </div>
          <div class="card-tags">
            <span class="tag" style="background:#c3f0ca">🥕 Veggie lover</span>
            <span class="tag" style="background:#fff0b3">Fluffy</span>
          </div>
        </div>
      </div>
      <!-- Card 2 (middle) -->
      <div class="pet-card">
        <div class="card-emoji" style="--bg1:#ffd6e7;--bg2:#ff4f8b">🐱</div>
        <div class="card-body">
          <div class="card-name-row">
            <span class="card-name">Luna</span>
            <span class="card-age">3 yrs</span>
          </div>
          <div class="card-tags">
            <span class="tag" style="background:#ffd6e7">🎀 Fancy</span>
            <span class="tag" style="background:#e0d4fc">Indoor queen</span>
          </div>
        </div>
      </div>
      <!-- Card 1 (top) -->
      <div class="pet-card" id="topCard">
        <div class="card-emoji" style="--bg1:#ffe8c8;--bg2:#ff6b35">🐶</div>
        <div class="card-body">
          <div class="card-name-row">
            <span class="card-name">Cooper</span>
            <span class="card-age">4 yrs</span>
          </div>
          <div class="card-tags">
            <span class="tag" style="background:#ffe8c8">🏃 Loves zoomies</span>
            <span class="tag" style="background:#d4f0fc">Swimmer</span>
          </div>
          <p class="card-bio">Professional stick chaser. Certified good boy. Looking for someone to share my treats with 🦴</p>
        </div>
      </div>
    </div>
    <div class="swipe-btns">
      <button class="swipe-btn nope" title="Pass" onclick="swipeCard('left')">👎</button>
      <button class="swipe-btn super" title="Super like" onclick="swipeCard('super')">⭐</button>
      <button class="swipe-btn like" title="Like" onclick="swipeCard('right')">❤️</button>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-section">
  <h2>🐾 How PawMatch Works</h2>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <div class="step-icon">📸</div>
      <h3>Create a Profile</h3>
      <p>Add your pet's best photos, their hobbies, favorite snacks and personality quirks.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <div class="step-icon">👆</div>
      <h3>Swipe & Discover</h3>
      <p>Browse adorable pets nearby. Swipe right to like, left to pass. It's paw-sitively addictive.</p>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <div class="step-icon">💌</div>
      <h3>It's a Match!</h3>
      <p>When two pets like each other, it's a match! Their owners can arrange a playdate.</p>
    </div>
    <div class="step">
      <div class="step-num">04</div>
